{
  "name": "ark-note",
  "version": "1.0.3",
  "description": "A secure, cross-platform encrypted note-taking application",
  "author": {
    "name": "Eric",
    "email": "erickent1995@gmail.com"
  },
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "dev": "vite",
    "verify:icons": "node scripts/verify-icons.mjs",
    "test:brand": "node scripts/test-branding.mjs",
    "test:auth": "node scripts/test-auth-security.mjs",
    "test:sync": "node scripts/test-sync-service.mjs",
    "test:markdown": "node scripts/test-markdown-renderer.mjs",
    "build": "npm run verify:icons && npm run test:brand && npm run test:auth && npm run test:sync && npm run test:markdown && vite build",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis --x64 --ia32",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux AppImage deb rpm --x64"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@fontsource/inter": "^5.2.8",
    "@lezer/highlight": "^1.2.1",
    "codemirror": "^6.0.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.8",
    "harmonyos-sans-sc-webfont-splitted": "^1.1.0",
    "lucide-react": "^0.468.0",
    "markdown-it": "^14.1.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.14.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.12",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.arknote.app",
    "productName": "arkNote",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons"
      },
      {
        "from": "public/icon.ico",
        "to": "icons/icon.ico"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "maintainer": "Eric <erickent1995@gmail.com>",
      "category": "Office",
      "executableName": "ark-note",
      "icon": "build/icons",
      "desktop": {
        "StartupWMClass": "ark-note"
      },
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": null,
      "category": "public.app-category.productivity",
      "icon": "public/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
